# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# backups de limpeza de dados (contêm dados pessoais — nunca commitar)
scripts/backup-*.json

# materiais locais (dados sensíveis / referências pessoais — nunca commitar)
/contratos/
/Imagens_referencia_CRM/
/Imagens_referencia_campanhas/
/imagens_referencia_relatorios/
/prints_aleatorios/
/print_erro/
/automacao_make_exemplo/

# claude code (configs locais)
.claude/settings.local.json
.claude/launch.json

# backups locais de planos
*.local.bak

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
