NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-region.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.[project-ref]:[password]@aws-region.pooler.supabase.com:5432/postgres
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
# Chave da OpenAI para o Copilot (Chat com IA). Server-only — NUNCA usar NEXT_PUBLIC.
# Obtenha em platform.openai.com -> API keys e cole em .env.local (nunca commitar).
OPENAI_API_KEY=
# Modelo usado pelo Copilot (opcional). Default: gpt-4o-mini se ausente.
OPENAI_MODEL=gpt-4o-mini
# Meta Ads API (System User Token). Server-only — NUNCA usar NEXT_PUBLIC.
META_SYSTEM_USER_TOKEN=
META_BUSINESS_ID=
META_API_VERSION=v25.0
# Inngest (Event Key para producao — dev mode nao precisa)
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
# Google Calendar (OAuth 2.0) — server-only, EXCETO NEXT_PUBLIC_APP_URL.
# Crie em Google Cloud Console -> Credentials -> OAuth Client ID (Web application).
# Redirect URI autorizado: {NEXT_PUBLIC_APP_URL}/api/integrations/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# URL pública do app (usada para montar o redirect do OAuth). Em dev pode omitir (fallback http://localhost:3000).
NEXT_PUBLIC_APP_URL=
